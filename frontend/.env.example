# Frontend configuration (Vite). Copy to .env to override.

# Where the FastAPI backend lives. In dev the Vite proxy forwards /api, /health,
# /static, and /metrics here (see vite.config.ts) so you can leave VITE_API_BASE
# unset and call same-origin paths.
VITE_BACKEND_URL=http://localhost:8000

# Optional: call the API at an absolute base instead of the dev proxy
# (e.g. when serving the built SPA separately from the API).
# VITE_API_BASE=https://api.your-domain.com
