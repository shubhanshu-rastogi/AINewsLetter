# =============================================================================
# Agentic AI Newsletter Platform — environment configuration
# =============================================================================
# Copy to `.env` and edit. THE DEFAULTS RUN THE WHOLE PLATFORM OFFLINE WITH NO
# API KEYS. Every external integration is behind an ENABLE_* flag that is off by
# default; provide a key only when you turn its flag on.
# Authoritative schema: app/core/config.py
# =============================================================================

# ---- Application ----
APP_NAME=Agentic AI Newsletter Platform
APP_ENV=local                 # local | staging | production
DEBUG=false
API_V1_PREFIX=/api/v1

# ---- Logging ----
LOG_LEVEL=INFO
LOG_JSON=true

# ---- PostgreSQL ----
# POSTGRES_HOST=db when running via docker-compose, localhost for bare metal.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ainewsletter
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres    # CHANGE for any real deployment (insecure default)
# DATABASE_URL_OVERRIDE=      # explicit DSN; otherwise derived from POSTGRES_*
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_PRE_PING=true
DB_ECHO=false

# ---- LLM providers ----
# Needed only when an ENABLE_LLM_* flag below is true.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=anthropic        # anthropic | openai
LLM_MODEL=claude-haiku-4-5-20251001

# ---- Source collection ----
COLLECTION_TIMEOUT=20
MAX_RETRIES=3
RSS_BATCH_SIZE=25
RESEARCH_BATCH_SIZE=15
NEWSLETTER_BATCH_SIZE=15
ENABLE_SCHEDULER=true         # weekly automated runs (enable on ONE instance only)
RESPECT_ROBOTS_TXT=true

# ---- Relevance / categorization ----
ENABLE_LLM_CLASSIFICATION=false   # true -> uses ANTHROPIC/OPENAI key

# ---- Fact checking ----
FACT_CHECK_VERIFY_URLS=true
ENABLE_LLM_FACTCHECK=false        # true -> uses ANTHROPIC/OPENAI key
MAX_CLAIMS_PER_ARTICLE=10

# ---- Newsletter writer / brand ----
NEWSLETTER_NAME=AI & Quality Engineering Weekly
NEWSLETTER_TAGLINE=Practical AI insights for QA Leaders, Test Managers, Engineering Leaders, and IT Professionals.
ENABLE_LLM_WRITER=false           # true -> uses ANTHROPIC/OPENAI key
MIN_CONFIDENCE_FOR_PUBLISH=90.0

# ---- Visual generation ----
VISUAL_STORAGE_ROOT=storage
VISUAL_BASE_URL=/static
ENABLE_AI_IMAGES=false            # false -> programmatic cover; true -> needs OPENAI_API_KEY
AI_IMAGE_MODEL=gpt-image-1

# ---- Human review / feedback ----
ENABLE_LLM_FEEDBACK=false         # true -> uses ANTHROPIC/OPENAI key
NOTION_API_KEY=                   # + NOTION_REVIEW_DATABASE_ID to mirror reviews to Notion
NOTION_REVIEW_DATABASE_ID=
REVIEW_AUTH_TOKEN=                # if set, review/publish/subscriber routes need Bearer token

# ---- Publishing ----
ENABLE_REAL_PUBLISHING=false      # false -> simulated (no external calls)
BEEHIIV_API_KEY=                  # + BEEHIIV_PUBLICATION_ID for real Beehiiv publishing
BEEHIIV_PUBLICATION_ID=
LINKEDIN_CLIENT_ID=               # + secret + author URN for real LinkedIn publishing
LINKEDIN_CLIENT_SECRET=
LINKEDIN_AUTHOR_URN=
NEWSLETTER_SUBSCRIBE_URL=https://aiqeweekly.example.com/subscribe
MAX_PUBLISH_RETRIES=3
PUBLISH_RETRY_BASE_DELAY=1.0

# ---- Platform / operations ----
SERVICE_NAME=ainewsletter-api
SECRET_KEY=                       # REQUIRED in staging/production

# Redis (optional; falls back to in-memory when disabled)
ENABLE_REDIS=false
REDIS_URL=                        # e.g. redis://localhost:6379/0

# Observability
ENABLE_METRICS=true
ENABLE_TRACING=false
OTEL_EXPORTER_OTLP_ENDPOINT=

# Security / HTTP hardening
CORS_ORIGINS=*                    # comma-separated; wildcard rejected in production
MAX_REQUEST_BYTES=2000000
ENABLE_SECURITY_HEADERS=true

# Rate limiting
ENABLE_RATE_LIMIT=true
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_BURST=30

# Idempotency
ENABLE_IDEMPOTENCY=true
IDEMPOTENCY_TTL_SECONDS=86400

# Database hardening
DB_STATEMENT_TIMEOUT_MS=30000
DB_SLOW_QUERY_MS=500.0
