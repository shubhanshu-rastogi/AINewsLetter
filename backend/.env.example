# ---- Application ----
APP_NAME=Agentic AI Newsletter Platform
APP_ENV=local
DEBUG=false
API_V1_PREFIX=/api/v1

# ---- Logging ----
LOG_LEVEL=INFO
LOG_JSON=true

# ---- PostgreSQL ----
# Use POSTGRES_HOST=db when running via docker-compose, localhost for bare metal.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ainewsletter
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ---- LLM providers (placeholders - integrations are future work) ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- External integrations (placeholders - future work) ----
BEEHIIV_API_KEY=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
NOTION_API_KEY=

# ---- Source collection ----
COLLECTION_TIMEOUT=20
MAX_RETRIES=3
RSS_BATCH_SIZE=25
RESEARCH_BATCH_SIZE=15
NEWSLETTER_BATCH_SIZE=15
ENABLE_SCHEDULER=true
RESPECT_ROBOTS_TXT=true
