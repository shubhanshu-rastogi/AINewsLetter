# Production environment template.
# ALL secrets MUST come from the deployment secret manager (never committed).
# The app refuses to start if SECRET_KEY / a strong POSTGRES_PASSWORD / non-wildcard
# CORS_ORIGINS (and BEEHIIV_API_KEY when real publishing is on) are missing.
APP_ENV=production
DEBUG=false
LOG_JSON=true
LOG_LEVEL=INFO

POSTGRES_HOST=db
ENABLE_SCHEDULER=true
ENABLE_REDIS=true
ENABLE_METRICS=true
ENABLE_TRACING=true
ENABLE_RATE_LIMIT=true
ENABLE_REAL_PUBLISHING=true
CORS_ORIGINS=https://aiqeweekly.example.com
RATE_LIMIT_PER_MINUTE=120

# Injected at deploy time (examples — DO NOT hardcode real values):
# SECRET_KEY=
# POSTGRES_PASSWORD=
# DATABASE_URL_OVERRIDE=
# REDIS_URL=redis://redis:6379/0
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# BEEHIIV_API_KEY=
# BEEHIIV_PUBLICATION_ID=
# NOTION_API_KEY=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# LINKEDIN_AUTHOR_URN=
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
