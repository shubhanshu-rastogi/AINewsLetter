# Development environment overrides (layered on top of .env).
# Safe defaults — never put real secrets here.
APP_ENV=development
DEBUG=true
LOG_JSON=false

POSTGRES_HOST=localhost
POSTGRES_DB=ainewsletter
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

ENABLE_SCHEDULER=false
ENABLE_REDIS=false
ENABLE_REAL_PUBLISHING=false
ENABLE_AI_IMAGES=false
ENABLE_METRICS=true
ENABLE_RATE_LIMIT=true
CORS_ORIGINS=*
SECRET_KEY=dev-secret-not-for-production
