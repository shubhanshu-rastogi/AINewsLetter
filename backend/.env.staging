# Staging environment template.
# Real secrets must be injected via the deployment environment / secret manager,
# NOT committed here. Startup fails fast if required values are missing.
APP_ENV=staging
DEBUG=false
LOG_JSON=true

# Provide via secret manager:
# SECRET_KEY=
# POSTGRES_PASSWORD=
# DATABASE_URL_OVERRIDE=
# REDIS_URL=
# OPENAI_API_KEY= / ANTHROPIC_API_KEY= / BEEHIIV_API_KEY= / NOTION_API_KEY= / LINKEDIN_CLIENT_SECRET=

POSTGRES_HOST=db
ENABLE_SCHEDULER=true
ENABLE_REDIS=true
ENABLE_METRICS=true
ENABLE_TRACING=true
ENABLE_RATE_LIMIT=true
ENABLE_REAL_PUBLISHING=false
CORS_ORIGINS=https://staging.aiqeweekly.example.com
